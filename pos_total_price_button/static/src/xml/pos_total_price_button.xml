<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="pos_total_price_button.ControlButtons"
       t-inherit="point_of_sale.ControlButtons"
       t-inherit-mode="extension">
        <xpath expr="//button[hasclass('more-btn')]" position="before">
            <button type="button" t-att-class="buttonClass + (isTotalPriceMode ? ' active' : '')" t-if="!props.showRemainingButtons" t-att-disabled="!isTotalPriceEnabled" t-on-click="onClickTotalPrice">
                <span>Total Price</span>
            </button>
        </xpath>
    </t>
</templates>
